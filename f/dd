-- 6. current sharepoint process status, source path, timing and bronze destination
select flp.flpConfigurationId, flp.process_name, flp.is_active as configurationActive, flp.created_date, flp.modified_date, a.displayname as applicationName, aps.sitename as siteName, sp.sharePointLibraryName, sp.sharePointFolderPath, sc.scheduleTypeId, st.schedulerType, sc.scheduleStartDate, sc.scheduleStartTime, sc.scheduleEndDate, sc.scheduleEndTime, ps.nextRun, ps.lastrun, ps.flpProcessStatusId, fps.statusName as processStatus, ctm.tableName as bronzeTableName, ctm.historyTableName, dc.databaseName as bronzeDatabaseName, dc.databaseServer, dc.databaseConnectionSecret
from dbo.di_flpConfiguration flp
left join dbo.di_flpSharePointSource sp on sp.flpConfigurationId = flp.flpConfigurationId and sp.active = 1
left join dbo.di_application a on a.applicationid = sp.sharePointApplicationId
left join dbo.di_applicationsite aps on aps.applicationsiteid = sp.sharePointApplicationSiteId
left join dbo.di_flpSchedulerConfiguration sc on sc.flpConfigurationId = flp.flpConfigurationId and sc.active = 1
left join dbo.di_info_schedulerType st on st.schedulerTypeId = sc.scheduleTypeId
left join dbo.di_processScheduler ps on ps.flpConfigurationId = flp.flpConfigurationId and ps.active = 1
left join dbo.di_info_flpProcessStatus fps on fps.id = ps.flpProcessStatusId
left join dbo.di_configurationTableMapping ctm on ctm.flpConfigurationId = flp.flpConfigurationId and ctm.active = 1
left join dbo.di_databaseConfiguration dc on dc.id = ctm.databaseConfigurationId
where flp.processTypeId = 6
order by flp.created_date desc;

